{
  "name": "codeflow",
  "displayName": "CodeFlow",
  "description": "",
  "version": "0.0.1",
  "publisher": "stanley",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeflow.displayWelcomeMessage",
        "title": "Display Welcome Message"
      },
      {
        "command": "codeflow.displayCurrentTime",
        "title": "Display Current Time"
      }
    ],
    "keybindings": [
      {
        "command": "codeflow.displayWelcomeMessage",
        "key": "cmd+shift+w",
        "when": "editorTextFocus"
      },
      {
        "command": "codeflow.displayCurrentTime",
        "key": "cmd+shift+t",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
